NODE_ENV=development
PORT=3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/mydb?schema=public"

# CORS
# Frontend dev origin (Vite default)
CORS_ORIGIN="http://localhost:5173"

# Auth
# Use strong random strings in production
JWT_ACCESS_SECRET="change_me_access_secret"
JWT_REFRESH_SECRET="change_me_refresh_secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"
BCRYPT_ROUNDS=12

# AI (Google Gemini)
GEMINI_API_KEY="change_me"
GEMINI_MODEL="gemini-2.0-flash"

# Cloudinary (image storage)
CLOUDINARY_CLOUD_NAME="change_me"
CLOUDINARY_API_KEY="change_me"
CLOUDINARY_API_SECRET="change_me"

# Email (SMTP)
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="change_me"
SMTP_PASS="change_me"
SMTP_FROM="SmartMeter <no-reply@smartmeter.local>"

# App URLs
APP_URL="http://localhost:5173"

# Defaults / business rules
DEFAULT_CONFIDENCE_THRESHOLD=0.75
BILL_DUE_DAYS=15
