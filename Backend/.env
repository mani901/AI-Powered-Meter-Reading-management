NODE_ENV=development
PORT=3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=9999999999

# Database
DATABASE_URL="postgresql://postgres:rehman123@localhost:5432/AiPoweredMeterReadingDb?schema=public"

# CORS
CORS_ORIGIN="http://localhost:5173"

# Auth
JWT_ACCESS_SECRET="dev_access_secret_change_me"
JWT_REFRESH_SECRET="dev_refresh_secret_change_me"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"
BCRYPT_ROUNDS=12

# Meter AI (Python FastAPI — run: uvicorn main:app from model/)
METER_AI_URL="http://localhost:8000"

# Cloudinary
CLOUDINARY_CLOUD_NAME="replace_me"
CLOUDINARY_API_KEY="replace_me"
CLOUDINARY_API_SECRET="replace_me"

# Email (SMTP)
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="replace_me"
SMTP_PASS="replace_me"
SMTP_FROM="SmartMeter <no-reply@smartmeter.local>"

# App URLs
APP_URL="http://localhost:5173"

# Defaults
DEFAULT_CONFIDENCE_THRESHOLD=0.75
BILL_DUE_DAYS=15
